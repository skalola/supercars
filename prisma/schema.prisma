generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Make {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  models    Model[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Model {
  id                  String      @id @default(uuid())
  makeId              String
  name                String
  slug                String
  years               String?
  productionStartYear Int?
  productionEndYear   Int?
  category            String?
  bodyStyle           String?
  productionCount     Int?
  description         String?

  make                Make        @relation(fields: [makeId], references: [id])
  vehicles            Vehicle[]
  spec                ModelSpec?
  images              ModelImage[]
  variants            ModelVariant[]
  garageItems         GarageItem[]
  maintenanceRules    MaintenanceRule[]

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@unique([makeId, slug])
}

model ModelSpec {
  id            String   @id @default(uuid())
  modelId       String   @unique
  engine        String?
  displacement  String?
  cylinders     String?
  horsepower    String?
  torque        String?
  transmission  String?
  drivetrain    String?
  topSpeed      String?
  zeroToSixty   String?
  weight        String?

  model         Model    @relation(fields: [modelId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ModelVariant {
  id                  String   @id @default(uuid())
  modelId             String
  name                String
  slug                String
  productionStartYear Int?
  productionEndYear   Int?
  productionCount     Int?
  description         String?

  model               Model    @relation(fields: [modelId], references: [id])

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([modelId, slug])
}

model ModelImage {
  id        String   @id @default(uuid())
  modelId   String
  url       String
  source    String?
  type      String?

  model     Model    @relation(fields: [modelId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([modelId, url])
}

model Vehicle {
  id           String @id @default(uuid())
  vin          String @unique
  modelId      String
  year         Int
  
  // Identity
  trim         String?
  series       String?
  manufacturer String?
  destinationMarket String?
  
  // Details
  color        String?
  mileage      Int?
  bodyStyle    String?
  vehicleType  String?
  doors        String?
  fuelType     String?
  
  // Engine & Performance
  engine       String?
  engineConfiguration String?
  engineCylinders String?
  displacement String?
  turbo        String?
  transmission String?
  transmissionSpeeds String?
  drivetrain   String?
  engineHP     String?
  engineKW     String?
  engineManufacturer String?
  
  // Manufacturing
  plantCountry String?
  plantCity    String?
  plantState   String?
  
  // Safety
  abs                  String?
  esc                  String?
  tpms                 String?
  rearVisibilitySystem String?
  parkAssist           String?
  adaptiveDrivingBeam  String?
  airBagLocFront       String?
  airBagLocKnee        String?
  airBagLocSide        String?
  pretensioner         String?
  seatBeltsAll         String?

  // Others
  gvwr         String?
  brakeSystem  String?
  electrificationLevel String?
  
  status       String @default("UNCLAIMED")
  ownerId      String?

  model        Model @relation(fields: [modelId], references: [id])
  owner        User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  images       VehicleImage[]
  profile      VehicleProfile?
  modifications VehicleModification[]
  serviceRecords ServiceRecord[]
  awards       VehicleAward[]
  photos       VehiclePhoto[]
  documents    VehicleDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VehicleImage {
  id          String   @id @default(uuid())
  vehicleId   String
  url         String
  alt         String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  username      String?   @unique
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]
  garageItems   GarageItem[]
  vehicles      Vehicle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GarageItem {
  id        String   @id @default(cuid())
  userId    String
  modelId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  model     Model    @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([userId, modelId])
}

model VehicleProfile {
  id             String   @id @default(uuid())
  vehicleId      String   @unique
  exteriorColor  String?
  interiorColor  String?
  currentMileage Int?
  ownerNotes     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model VehicleModification {
  id             String   @id @default(uuid())
  vehicleId      String
  name           String
  brand          String?
  description    String?
  installedDate  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model ServiceRecord {
  id             String   @id @default(uuid())
  vehicleId      String
  serviceDate    DateTime
  mileage        Int?
  shopName       String?
  description    String?
  cost           Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model VehicleAward {
  id             String   @id @default(uuid())
  vehicleId      String
  title          String
  eventName      String?
  awardDate      DateTime?
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  vehicle        Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model VehiclePhoto {
  id           String   @id @default(uuid())
  vehicleId    String
  filePath     String
  caption      String?
  displayOrder Int      @default(0)
  isHero       Boolean  @default(false)
  createdAt    DateTime @default(now())

  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model VehicleDocument {
  id           String   @id @default(uuid())
  vehicleId    String
  title        String
  documentType String
  filePath     String
  createdAt    DateTime @default(now())

  vehicle      Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model MaintenanceRule {
  id             String   @id @default(uuid())
  modelId        String?
  category       String
  serviceName    String
  description    String?
  intervalMiles  Int?
  intervalMonths Int?
  priority       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  model          Model?   @relation(fields: [modelId], references: [id], onDelete: Cascade)
}
